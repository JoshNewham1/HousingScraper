# Per-instance search configuration.
# Copy this file to .env.<name> (e.g. .env.my-search) for each search profile.

GUMTREE_LINK=your_gumtree_search_link
RIGHTMOVE_LINK=your_rightmove_search_link
RECIPIENT_EMAIL=recipient_1@example.com;recipient_2@example.com

# Leave blank to receive all listings regardless of date
START_DATE_FILTER=2026-07-01

# Cron schedule (UTC). Leave blank to default to 9am UTC daily.
SCHEDULE=cron(0 9 * * ? *)
